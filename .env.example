# Public URL used when generating share links.
# Leave blank to use the current browser origin.
VITE_BASE_URL=http://localhost:5173

# Clerk authentication. Leave blank to use the built-in local guest account.
VITE_CLERK_PUBLISHABLE_KEY=

# Strapi backend. Leave VITE_API_BASE_URL blank to store resumes in localStorage.
VITE_API_BASE_URL=http://localhost:1337
VITE_STRAPI_API_KEY=

# Google Gemini. Leave blank to disable AI generation buttons.
VITE_GOOGLE_AI_API_KEY=
